# Database URL — use PostgreSQL for production, SQLite for development
# PostgreSQL: postgresql://user:password@localhost:5432/banklite
# SQLite:     sqlite:///banklite.db
DATABASE_URL=sqlite:///banklite.db

# Flask secret key — generate a strong random string for production
SECRET_KEY=change-me-to-a-secure-random-string

# Flask environment: development | production
FLASK_ENV=development

# Server port
PORT=5000
